# Copy this file to .env.local and fill in your own server-side key.
# Never commit .env.local. It is already ignored by .gitignore.

# OpenAI-compatible mode is recommended. Examples:
# https://api.openai.com/v1
# https://api.deepseek.com
# https://dashscope.aliyuncs.com/compatible-mode
AI_API_FORMAT=openai-compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace-with-your-api-key
AI_API_MODEL=gpt-4o-mini
AI_API_TIMEOUT_MS=60000

# Optional local fallback. Keep false when you expect real model output.
AI_USE_MOCK=false
